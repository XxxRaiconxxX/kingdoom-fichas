{
  "name": "kingdoom-fichas",
  "private": true,
  "version": "5.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "sync": "npm run build && cap sync android",
    "apk:debug": "npm run sync && cd android && gradlew.bat assembleDebug",
    "apk:release": "npm run sync && cd android && gradlew.bat assembleRelease",
    "android:open": "npm run sync && cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.4.0",
    "@capacitor/share": "^8.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/cinzel": "^5.2.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
